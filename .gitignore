# =============================================================================
# .gitignore — never commit secrets, caches, or build artefacts
# =============================================================================

# ── Secrets / env ─────────────────────────────────────────────────────────────
.env
*.env
*.secret

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Kubernetes generated backups ──────────────────────────────────────────────
k8s/*.bak

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore
