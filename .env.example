# =============================================================================
# Environment Variables — copy this file to .env and fill in your values
#   cp .env.example .env
# =============================================================================

# ── Docker Hub credentials ────────────────────────────────────────────────────
# Your Docker Hub username (https://hub.docker.com)
DOCKER_USERNAME=your-dockerhub-username

# Docker Hub access token  (NOT your password)
# Generate at: https://hub.docker.com/settings/security → New Access Token
DOCKERHUB_TOKEN=your-dockerhub-access-token

# ── Application settings ──────────────────────────────────────────────────────
APP_VERSION=1.0.0
ENVIRONMENT=development

# Flask debug mode (true | false) — never set to true in production
FLASK_DEBUG=false

# Port the app listens on inside the container
PORT=5000

# ── GitHub Actions (set as repo secrets, not here) ───────────────────────────
# Repository → Settings → Secrets and variables → Actions
#   DOCKERHUB_USERNAME   ← same as DOCKER_USERNAME above
#   DOCKERHUB_TOKEN      ← same as DOCKERHUB_TOKEN above
